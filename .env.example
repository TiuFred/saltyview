# Copie este arquivo para .env e preencha os valores reais. Nunca commite o .env.

# --- Banco de dados ---
POSTGRES_USER=casa
POSTGRES_PASSWORD=change-me
POSTGRES_DB=casa
POSTGRES_PORT=5432
DATABASE_URL=postgresql://casa:change-me@localhost:5432/casa?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API (NestJS) ---
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# JWT - gere segredos fortes e distintos para access e refresh, ex: `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Seed do usuário administrador inicial (criado por `npm run prisma:seed`)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_PIN=0000

# --- Integração SmartThings (Samsung) ---
# Gere um Personal Access Token em https://account.smartthings.com/tokens
# Escopos necessários: devices (r/x), scenes (nenhum necessário nesta fase)
SMARTTHINGS_PAT=

# --- Integração LG ThinQ (SDK oficial "thinqconnect") ---
# Gere um Personal Access Token em https://smartsolution.developer.lge.com (ThinQ Connect > PAT)
LG_THINQ_PAT=
# Gere UMA vez com `node -e "console.log(crypto.randomUUID())"` e mantenha estável (não regenerar a cada deploy)
LG_THINQ_CLIENT_ID=
LG_THINQ_COUNTRY=BR

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
